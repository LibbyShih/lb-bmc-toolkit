    {
      "id": "obmcutil",
      "title": "obmcutil — OpenBMC 狀態管理",
      "icon": "⚙️",
      "probe": "obmcutil",
      "notes": [
        {
          "type": "syntax",
          "text": "<code>obmcutil [--wait] [--verbose] [--id=&lt;INSTANCE_ID&gt;] &lt;command&gt;</code>"
        }
      ],
      "groups": [
        {
          "title": null,
          "commands": [
            {
              "cmd": "obmcutil state",
              "desc": "顯示 BMC / Host / Chassis 完整狀態"
            },
            {
              "cmd": "obmcutil bmcstate",
              "desc": "顯示 BMC 自身狀態（Ready / NotReady）"
            },
            {
              "cmd": "obmcutil chassisstate",
              "desc": "顯示 Chassis 電源狀態"
            },
            {
              "cmd": "obmcutil hoststate",
              "desc": "顯示 Host 狀態"
            },
            {
              "cmd": "obmcutil osstate",
              "desc": "顯示 OS 啟動進度狀態"
            },
            {
              "cmd": "obmcutil bootprogress",
              "desc": "顯示 Host boot progress"
            },
            {
              "cmd": "obmcutil status",
              "desc": "簡短狀態摘要"
            },
            {
              "cmd": "obmcutil power",
              "desc": "顯示目前電源狀態"
            },
            {
              "cmd": "obmcutil poweron",
              "desc": "啟動 Host 電源",
              "dangerous": true
            },
            {
              "cmd": "obmcutil poweroff",
              "desc": "關閉 Host 電源（Graceful）",
              "dangerous": true
            },
            {
              "cmd": "obmcutil chassison",
              "desc": "啟動 Chassis 電源",
              "dangerous": true
            },
            {
              "cmd": "obmcutil chassisoff",
              "desc": "關閉 Chassis 電源",
              "dangerous": true
            },
            {
              "cmd": "obmcutil chassiskill",
              "desc": "強制關閉 Chassis 電源",
              "dangerous": true
            },
            {
              "cmd": "obmcutil hostrebooton",
              "desc": "啟用 Host 在 Quiesce 狀態自動重啟",
              "dangerous": true
            },
            {
              "cmd": "obmcutil hostrebootoff",
              "desc": "停用 Host 在 Quiesce 狀態自動重啟",
              "dangerous": true
            },
            {
              "cmd": "obmcutil bmcrebooton",
              "desc": "啟用 BMC 自動重啟",
              "dangerous": true
            },
            {
              "cmd": "obmcutil bmcrebootoff",
              "desc": "停用 BMC 自動重啟",
              "dangerous": true
            },
            {
              "cmd": "obmcutil recoveryon",
              "desc": "啟用 watchdog timeout + host crash 恢復",
              "dangerous": true
            },
            {
              "cmd": "obmcutil recoveryoff",
              "desc": "停用 watchdog timeout + host crash 恢復",
              "dangerous": true
            },
            {
              "cmd": "obmcutil recoverystatus",
              "desc": "顯示 recovery 及 auto-reboot 設定狀態"
            },
            {
              "cmd": "obmcutil listbootblock",
              "desc": "列出啟動階段錯誤記錄"
            },
            {
              "cmd": "obmcutil listlogs",
              "desc": "列出所有 phosphor-logging 事件"
            },
            {
              "cmd": "obmcutil showlog <log>",
              "desc": "顯示特定 log 詳細內容"
            },
            {
              "cmd": "obmcutil deletelogs",
              "desc": "刪除所有 phosphor-logging 事件",
              "dangerous": true
            },
            {
              "cmd": "obmcutil stopofftargets",
              "desc": "手動停止所有 obmc power-off targets",
              "dangerous": true
            }
          ]
        }
      ],
      "params_note": "<code>--wait / -w</code> → 等待狀態轉換完成才返回<br><code>--verbose / -v</code> → 搭配 --wait，將 journal 輸出到 stdout<br><code>--id=&lt;N&gt; / -i &lt;N&gt;</code> → 指定 instance ID（預設 0）<br><code>--force / -f</code> → 強制執行，忽略前置條件檢查"
    },
    {
      "id": "ipmitool",
      "title": "ipmitool — IPMI 管理",
      "icon": "🔌",
      "probe": "ipmitool",
      "notes": [
        {
          "type": "info",
          "text": "<strong>本地使用：</strong><code>ipmitool &lt;command&gt;</code><br><strong>遠端使用：</strong><code>ipmitool -H &lt;BMC_IP&gt; -U root -P '0penBmc' -I lanplus &lt;command&gt;</code><br><strong>從 Host 端：</strong><code>ssh root@localhost -p 2222</code> 登入後直接用 ipmitool"
        }
      ],
      "groups": [
        {
          "title": "BMC / MC 管理",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool mc info",
              "desc": "顯示 MC 基本資訊（Device ID, FW version, IPMI version）"
            },
            {
              "cmd": "ipmitool mc getenables",
              "desc": "顯示 MC 啟用功能"
            },
            {
              "cmd": "ipmitool mc setenables <option> on|off",
              "desc": "設定 MC 啟用功能"
            },
            {
              "cmd": "ipmitool mc reset cold",
              "desc": "Cold reset BMC",
              "dangerous": true
            },
            {
              "cmd": "ipmitool mc reset warm",
              "desc": "Warm reset BMC",
              "dangerous": true
            },
            {
              "cmd": "ipmitool mc watchdog get",
              "desc": "查詢 Watchdog 設定"
            },
            {
              "cmd": "ipmitool mc watchdog reset",
              "desc": "重置 Watchdog timer",
              "dangerous": true
            },
            {
              "cmd": "ipmitool mc watchdog off",
              "desc": "停用 Watchdog",
              "dangerous": true
            },
            {
              "cmd": "ipmitool mc guid",
              "desc": "顯示 MC GUID"
            }
          ]
        },
        {
          "title": "Chassis / Power 控制",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool chassis status",
              "desc": "顯示 Chassis 完整狀態"
            },
            {
              "cmd": "ipmitool chassis power status",
              "desc": "顯示目前電源 on/off"
            },
            {
              "cmd": "ipmitool chassis power on",
              "desc": "開機",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis power off",
              "desc": "強制關機",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis power soft",
              "desc": "Graceful 關機",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis power reset",
              "desc": "硬重啟",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis power cycle",
              "desc": "Power cycle（off → on）",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis bootdev pxe",
              "desc": "設定下次從 PXE 開機",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis bootdev disk",
              "desc": "設定從硬碟開機",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis bootdev bios",
              "desc": "設定進入 BIOS/UEFI",
              "dangerous": true
            },
            {
              "cmd": "ipmitool chassis bootparam get 5",
              "desc": "查詢目前 Boot flag 設定"
            }
          ]
        },
        {
          "title": "Sensor / SDR",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool sdr list",
              "desc": "列出所有感測器"
            },
            {
              "cmd": "ipmitool sdr type <type>",
              "desc": "篩選特定類型 (Temperature / Voltage / Fan / Current)"
            },
            {
              "cmd": "ipmitool sdr info",
              "desc": "顯示 SDR repository 資訊"
            },
            {
              "cmd": "ipmitool sensor list",
              "desc": "列出感測器詳細數值清單"
            },
            {
              "cmd": "ipmitool sensor get <name>",
              "desc": "查詢特定感測器"
            },
            {
              "cmd": "ipmitool sensor thresh <name> <threshold> <val>",
              "desc": "設定閾值 (unr/ucr/unc/lnc/lcr/lnr)",
              "dangerous": true
            },
            {
              "cmd": "ipmitool raw 0x04 0x2D <sensor_num>",
              "desc": "Raw 讀取感測器值",
              "dangerous": true
            }
          ]
        },
        {
          "title": "SEL (System Event Log)",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool sel list",
              "desc": "列出所有 SEL 事件"
            },
            {
              "cmd": "ipmitool sel info",
              "desc": "顯示 SEL repository 資訊及剩餘空間"
            },
            {
              "cmd": "ipmitool sel get <ID>",
              "desc": "查詢特定事件詳細內容"
            },
            {
              "cmd": "ipmitool sel clear",
              "desc": "清除所有 SEL 事件",
              "dangerous": true
            },
            {
              "cmd": "ipmitool sel delete <ID>",
              "desc": "刪除特定事件",
              "dangerous": true
            },
            {
              "cmd": "ipmitool sel elist",
              "desc": "列出 SEL（含感測器名稱，較易讀）"
            },
            {
              "cmd": "ipmitool sel time get",
              "desc": "顯示 SEL 時間"
            },
            {
              "cmd": "ipmitool sel time set <time>",
              "desc": "設定 SEL 時間",
              "dangerous": true
            }
          ]
        },
        {
          "title": "LAN / 網路設定",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool lan print",
              "desc": "顯示 LAN channel 設定（IP, MAC, Gateway）"
            },
            {
              "cmd": "ipmitool lan print <channel>",
              "desc": "指定 channel（通常 1）"
            },
            {
              "cmd": "ipmitool lan set <ch> ipaddr <ip>",
              "desc": "設定靜態 IP",
              "dangerous": true
            },
            {
              "cmd": "ipmitool lan set <ch> netmask <mask>",
              "desc": "設定子網路遮罩",
              "dangerous": true
            },
            {
              "cmd": "ipmitool lan set <ch> defgw ipaddr <gw>",
              "desc": "設定 Default Gateway",
              "dangerous": true
            },
            {
              "cmd": "ipmitool lan set <ch> ipsrc dhcp",
              "desc": "切換為 DHCP",
              "dangerous": true
            },
            {
              "cmd": "ipmitool lan set <ch> ipsrc static",
              "desc": "切換為靜態 IP",
              "dangerous": true
            }
          ]
        },
        {
          "title": "User 管理",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool user list",
              "desc": "列出所有使用者"
            },
            {
              "cmd": "ipmitool user list <channel>",
              "desc": "列出特定 channel 使用者"
            },
            {
              "cmd": "ipmitool user set name <id> <name>",
              "desc": "設定使用者名稱",
              "dangerous": true
            },
            {
              "cmd": "ipmitool user set password <id> <pw>",
              "desc": "設定密碼（最多 8 字元）",
              "dangerous": true
            },
            {
              "cmd": "ipmitool user enable <id>",
              "desc": "啟用使用者",
              "dangerous": true
            },
            {
              "cmd": "ipmitool user disable <id>",
              "desc": "停用使用者",
              "dangerous": true
            },
            {
              "cmd": "ipmitool user priv <id> <priv> <ch>",
              "desc": "設定權限 (4=Admin, 3=Operator, 2=User)",
              "dangerous": true
            }
          ]
        },
        {
          "title": "FRU / Raw",
          "collapsible": true,
          "commands": [
            {
              "cmd": "ipmitool fru list",
              "desc": "列出所有 FRU 裝置資訊"
            },
            {
              "cmd": "ipmitool fru read <id> <file>",
              "desc": "讀取 FRU 資料到檔案"
            },
            {
              "cmd": "ipmitool fru write <id> <file>",
              "desc": "寫入 FRU 資料",
              "dangerous": true
            },
            {
              "cmd": "ipmitool raw <netFn> <cmd> [data...]",
              "desc": "發出 Raw IPMI 指令",
              "dangerous": true
            },
            {
              "cmd": "ipmitool raw 0x06 0x01",
              "desc": "Get Device ID (raw 範例)",
              "dangerous": true
            },
            {
              "cmd": "ipmitool event <sensor> <event>",
              "desc": "發出模擬 IPMI event",
              "dangerous": true
            },
            {
              "cmd": "ipmitool dcmi power reading",
              "desc": "讀取 DCMI 功耗數據"
            }
          ]
        }
      ]
    },
    {
      "id": "services",
      "title": "服務清單 (Running Services)",
      "icon": "🗂️",
      "probe": "systemctl",
      "dynamic": "services_interactive"
    },
    {
      "id": "systemctl",
      "title": "systemctl / journalctl / timedatectl",
      "icon": "🔄",
      "probe": "systemctl",
      "groups": [
        {
          "title": "systemctl",
          "commands": [
            {
              "cmd": "systemctl list-units --type=service --state=running --no-pager",
              "desc": "列出所有 running service"
            },
            {
              "cmd": "systemctl list-units --type=service --state=failed --no-pager",
              "desc": "列出失敗的 service"
            },
            {
              "cmd": "systemctl status <service>",
              "desc": "查詢 service 狀態"
            },
            {
              "cmd": "systemctl start <service>",
              "desc": "啟動 service",
              "dangerous": true
            },
            {
              "cmd": "systemctl stop <service>",
              "desc": "停止 service",
              "dangerous": true
            },
            {
              "cmd": "systemctl restart <service>",
              "desc": "重啟 service",
              "dangerous": true
            },
            {
              "cmd": "systemctl enable <service>",
              "desc": "設為開機自動啟動",
              "dangerous": true
            },
            {
              "cmd": "systemctl disable <service>",
              "desc": "取消開機自動啟動",
              "dangerous": true
            },
            {
              "cmd": "systemctl is-active <service>",
              "desc": "確認是否 active"
            },
            {
              "cmd": "systemctl list-dependencies <service>",
              "desc": "顯示依賴關係"
            },
            {
              "cmd": "systemctl daemon-reload",
              "desc": "重新載入 unit 設定"
            },
            {
              "cmd": "systemd-analyze blame",
              "desc": "顯示各服務開機耗時"
            },
            {
              "cmd": "systemd-analyze critical-chain",
              "desc": "顯示開機關鍵路徑"
            }
          ]
        },
        {
          "title": "journalctl",
          "commands": [
            {
              "cmd": "journalctl -n 50 --no-pager",
              "desc": "顯示最近 50 行"
            },
            {
              "cmd": "journalctl -u <service> --no-pager -n 30",
              "desc": "查詢特定 service log"
            },
            {
              "cmd": "journalctl --since \"10 min ago\" --no-pager",
              "desc": "查詢最近 10 分鐘 log"
            },
            {
              "cmd": "journalctl -p err --no-pager",
              "desc": "只顯示 error 等級以上"
            }
          ]
        },
        {
          "title": "timedatectl",
          "commands": [
            {
              "cmd": "timedatectl status",
              "desc": "顯示時間及 NTP 狀態"
            },
            {
              "cmd": "timedatectl set-ntp true",
              "desc": "啟用 NTP 同步",
              "dangerous": true
            },
            {
              "cmd": "timedatectl set-time \"<YYYY-MM-DD HH:MM:SS>\"",
              "desc": "手動設定時間",
              "dangerous": true
            },
            {
              "cmd": "timedatectl set-timezone <zone>",
              "desc": "設定時區",
              "dangerous": true
            }
          ]
        }
      ]
    },
    {
