    {
      "id": "busctl",
      "title": "busctl — D-Bus 偵錯工具",
      "icon": "🚌",
      "probe": "busctl",
      "notes": [
        {
          "type": "syntax",
          "text": "<code>busctl [OPTIONS] COMMAND [SERVICE [OBJECT [INTERFACE ...]]]</code>"
        }
      ],
      "groups": [
        {
          "title": "常用動態指令",
          "commands": [
            {
              "cmd": "busctl tree <dbus_service>",
              "desc": "顯示 D-Bus object tree"
            },
            {
              "cmd": "busctl introspect <dbus_service> <path>",
              "desc": "查詢介面方法 (請手動輸入路徑)"
            }
          ]
        },
        {
          "title": "服務列舉 / Object Tree",
          "commands": [
            {
              "cmd": "busctl list --acquired --no-pager",
              "desc": "列出所有已取得 D-Bus name 的服務"
            },
            {
              "cmd": "busctl list --activatable --no-pager",
              "desc": "列出可自動啟動的 D-Bus 服務"
            },
            {
              "cmd": "busctl tree xyz.openbmc_project.State.BMC",
              "desc": "BMC 狀態 object tree"
            },
            {
              "cmd": "busctl tree xyz.openbmc_project.State.Host",
              "desc": "Host 狀態 object tree"
            },
            {
              "cmd": "busctl tree xyz.openbmc_project.State.Chassis",
              "desc": "Chassis 電源狀態 object tree"
